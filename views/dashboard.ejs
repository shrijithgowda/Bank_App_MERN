<%- include("partials/navbar") %>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #f5f7f6, #e8f3ef);
}

/* PAGE WRAPPER */
.container {
    padding: 30px;
}

/* WELCOME */
h1 {
    color: #0b3d2e;
    margin-bottom: 5px;
}

/* BALANCE CARD */
.balance-card {
    background: linear-gradient(135deg, #0b3d2e, #145c43);
    color: white;
    padding: 25px;
    border-radius: 15px;
    width: 300px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    margin-top: 15px;
    transition: 0.3s;
}

.balance-card:hover {
    transform: translateY(-5px);
}

.balance-card h2 {
    margin: 0;
}

/* ALERTS */
.success {
    color: green;
    font-weight: 500;
}

.error {
    color: red;
    font-weight: 500;
}

/* ACTION CARDS */
.actions {
    display: flex;
    gap: 20px;
    margin-top: 25px;
    flex-wrap: wrap;
}

.action-card {
    background: white;
    padding: 20px;
    border-radius: 12px;
    width: 180px;
    text-align: center;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    transition: 0.3s;
    cursor: pointer;
}

.action-card:hover {
    transform: translateY(-5px);
}

.action-card a {
    text-decoration: none;
    color: #0b3d2e;
    font-weight: bold;
}

/* TRANSACTION TABLE */
.table-container {
    margin-top: 40px;
    background: white;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

table {
    width: 100%;
    border-collapse: collapse;
}

th {
    background: #0b3d2e;
    color: white;
    padding: 12px;
}

td {
    text-align: center;
    padding: 10px;
    border-bottom: 1px solid #eee;
}

tr:hover {
    background: #f3f8f5;
    transition: 0.3s;
}

/* TYPE COLORS */
.credit {
    color: green;
    font-weight: bold;
}

.debit {
    color: red;
    font-weight: bold;
}
.top-section {
    display: grid;
    grid-template-columns: 320px 1fr;
    justify-content: space-between;
    align-items: start;
    gap: 60px;   /* 👈 creates visible space between sections */
    margin-top: 20px;
}

/* LEFT SIDE */
.balance-card {
    background: linear-gradient(135deg, #0b3d2e, #145c43);
    color: white;
    padding: 25px;
    border-radius: 15px;
    width: 280px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    transition: 0.3s;
    height: 150px;
}

/* RIGHT SIDE CHART */
.chart-box {
    background: white;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);

    width: 100%;
    max-width: 520px;
    height: 380px;

    margin-left: auto;   /* 👈 pushes it fully to right */
    display: flex;
    justify-content: center;
    align-items: center;
}
/* RESPONSIVE */
@media (max-width: 900px) {
    .top-section {
        flex-direction: column;
        align-items: flex-start;
    }

    .chart-box {
        width: 100%;
    }

    .balance-card {
        width: 100%;
    }
}
.btn {
    display: inline-block;
    margin-top: 15px;
    padding: 10px 15px;
    background: #0b3d2e;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.3s;
    width: 100%;
    text-align: center;
    font-weight: 500;
}

.btn:hover {
    background: #145c43;
    transform: translateY(-2px);
}
.statement-wrap {
    margin-top: 12px;
    width: 100%;
}
#balance {
    transition: all 0.3s ease;
}

</style>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="container">

    <h1>Welcome, <%= user.name %> 👋</h1>

    <% if (success.length > 0) { %>
        <p class="success"><%= success %></p>
    <% } %>

    <% if (error.length > 0) { %>
        <p class="error"><%= error %></p>
    <% } %>

    <!-- BALANCE -->
<!-- TOP SECTION: BALANCE + CHART -->
<div class="top-section">

    <!-- BALANCE CARD -->
   <!-- LEFT COLUMN -->
<div>

    <div class="balance-card">
        <h3>💰 Current Balance</h3>
        <h2>₹<span id="balance"><%= user.balance %></span></h2>
    </div>

    <div class="statement-wrap">
        <a href="/statement/pdf" class="btn">
            📄 Download Statement
        </a>
    </div>

</div>

    <!-- CHART -->
   <div class="chart-box">
    <canvas id="txnChart"></canvas>
</div>

</div>



    <!-- ACTIONS -->
    <div class="actions">

        <div class="action-card">
            💳<br>
            <a href="/deposit">Deposit</a>
        </div>

        <div class="action-card">
            💸<br>
            <a href="/withdraw">Withdraw</a>
        </div>

        <div class="action-card">
            🔄<br>
            <a href="/transfer">Transfer</a>
        </div>

    </div>

    <!-- TRANSACTIONS -->
    <div class="table-container">
        <h3>📊 Transaction History</h3>

        <table>
            <tr>
                <th>Type</th>
                <th>Amount</th>
                <th>Balance After</th>
                <th>Date</th>
            </tr>

            <% transactions.forEach(txn => { %>
                <tr>
                    <td class="<%= txn.type.toLowerCase() %>">
                        <%= txn.type %>
                    </td>
                    <td>₹<%= txn.amount %></td>
                    <td>₹<%= txn.balanceAfter %></td>
                    <td><%= txn.date.toLocaleString() %></td>
                </tr>
            <% }) %>
        </table>
    </div>

</div>
<script>
const ctx = document.getElementById('txnChart');

new Chart(ctx, {
    type: 'doughnut',
    data: {
        labels: ['Credit (Income)', 'Debit (Expense)'],
        datasets: [{
            data: [<%= credit %>, <%= debit %>],
            backgroundColor: [
                '#0b3d2e',
                '#ff4d4d'
            ],
            borderWidth: 1
        }]
    },
    options: {
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});

const finalBalance = <%= user.balance %>;
const balanceEl = document.getElementById("balance");

let current = 0;
const duration = 1300; // 1.2 sec animation
const stepTime = 20;
const steps = duration / stepTime;
const increment = finalBalance / steps;

const counter = setInterval(() => {
    current += increment;

    if (current >= finalBalance) {
        current = finalBalance;
        clearInterval(counter);
    }

    balanceEl.innerText = Math.floor(current);
}, stepTime);
</script>
</body>
</html>