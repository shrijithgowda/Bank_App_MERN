<!DOCTYPE html>
<html>
<head>
    <title>Bank App</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f5f7f6, #e8f3ef);
        }

        /* NAVBAR */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 30px;

            background: linear-gradient(
                90deg,
                #0b3d2e 0%,
                #ffffff 60%
            );

            box-shadow: 0 4px 15px rgba(0,0,0,0.12);
            position: sticky;
            top: 0;
        }

        nav h2 {
            color: #0b3d2e;
            margin: 0;
            font-weight: bold;
        }

        nav a {
            text-decoration: none;
            color: #0b3d2e;
            margin-left: 15px;
            font-weight: 500;
            transition: 0.3s;
        }

        nav a:hover {
            color: #145c43;
            transform: translateY(-2px);
        }

        /* HERO */
        .hero {
            text-align: center;
            padding: 80px 20px 40px;
        }

        .hero h1 {
            color: #0b3d2e;
            font-size: 42px;
        }

        .hero p {
            color: #555;
            font-size: 18px;
            max-width: 600px;
            margin: auto;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 22px;
            background: linear-gradient(90deg, #0b3d2e, #145c43);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            transition: 0.3s;
        }

        .btn:hover {
            transform: scale(1.05);
        }

        /* FEATURES */
        .features {
            display: flex;
            justify-content: center;
            gap: 20px;
            padding: 40px;
            flex-wrap: wrap;
        }

        .feature-card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            width: 250px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            transition: 0.3s;
            text-align: center;
        }

        .feature-card:hover {
            transform: translateY(-5px);
        }

        .feature-card h3 {
            color: #0b3d2e;
        }

        /* QUOTE */
        .quote {
            text-align: center;
            padding: 50px 20px;
            font-style: italic;
            color: #444;
        }

        .quote span {
            display: block;
            margin-top: 10px;
            color: #0b3d2e;
            font-weight: bold;
        }

        /* SECURITY SECTION */
        .security {
            background: white;
            margin: 40px auto;
            padding: 40px;
            max-width: 900px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            text-align: center;
        }

        .security h2 {
            color: #0b3d2e;
        }

        /* FOOTER */
        footer {
            background: #0b3d2e;
            color: white;
            text-align: center;
            padding: 20px;
            margin-top: 50px;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav>
        <h2>🏦 MyBank</h2>

        <div>
            <a href="/register">Register</a>
            <a href="/login">Login</a>
            <a href="/dashboard">Dashboard</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <!-- HERO -->
    <div class="hero">
        <h1>Welcome to MyBank</h1>
        <p>Secure, Fast & Simple Digital Banking Experience built for the future of money management.</p>
        <a href="/register" class="btn">Get Started</a>
    </div>

    <!-- FEATURES -->
    <div class="features">

        <div class="feature-card">
            <h3>💰 Instant Transfers</h3>
            <p>Send money instantly with high speed processing.</p>
        </div>

        <div class="feature-card">
            <h3>🔒 Secure Banking</h3>
            <p>Your data is protected with top-level security.</p>
        </div>

        <div class="feature-card">
            <h3>📊 Track Transactions</h3>
            <p>Monitor all deposits, withdrawals & transfers.</p>
        </div>

    </div>

    <!-- SECURITY SECTION -->
    <div class="security">
        <h2>🔐 Your Money is Safe With Us</h2>
        <p>
            We use session-based authentication, encrypted storage,
            and secure transaction logging to ensure complete safety.
        </p>
    </div>

    <!-- QUOTE -->
    <div class="quote">
        “Banking is not just about money, it’s about trust and security.”
        <span>— MyBank Philosophy</span>
    </div>

    <!-- FOOTER -->
    <footer>
        © 2026 MyBank | Secure Digital Banking System
    </footer>

</body>
</html>